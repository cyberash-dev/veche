{
  "mcpServers": {
    "veche": {
      "command": "node",
      "args": ["/absolute/path/to/dist/bin/veche-server.js"],
      "env": {
        "VECHE_STORE": "file",
        "VECHE_HOME": "/Users/you/.veche",
        "VECHE_LOG_LEVEL": "info",
        "VECHE_MAX_ROUNDS_CAP": "12",
        "CODEX_API_KEY": "sk-..."
      }
    }
  }
}
