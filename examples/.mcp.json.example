{
  "mcpServers": {
    "ai-meeting": {
      "command": "node",
      "args": ["/absolute/path/to/ai-meeting-server/dist/bin/ai-meeting-server.js"],
      "env": {
        "AI_MEETING_STORE": "file",
        "AI_MEETING_HOME": "/Users/you/.ai-meeting",
        "AI_MEETING_LOG_LEVEL": "info",
        "AI_MEETING_MAX_ROUNDS_CAP": "12",
        "CODEX_API_KEY": "sk-..."
      }
    }
  }
}
