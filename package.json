{
  "name": "veche",
  "version": "0.1.5",
  "description": "MCP server for bounded multi-agent committee meetings — Codex + Claude Code deliberate in rounds and self-extinguish on <PASS/>",
  "type": "module",
  "license": "MIT",
  "author": "cyberash <mail@cyberash.dev>",
  "homepage": "https://github.com/cyberash-dev/veche#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyberash-dev/veche.git"
  },
  "bugs": {
    "url": "https://github.com/cyberash-dev/veche/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "agents",
    "multi-agent",
    "committee",
    "deliberation",
    "claude-code",
    "codex",
    "anthropic",
    "openai",
    "stdio",
    "veche"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "bin": {
    "veche-server": "./dist/bin/veche-server.js",
    "veche": "./dist/bin/veche.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "examples",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/bin/veche-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "22.10.1",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
